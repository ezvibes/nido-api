# Copy this file to prod.env when production infrastructure is ready.
# Replace every REPLACE_ME value before enabling prod in the workflow dispatch options.

PROJECT_ID=REPLACE_ME_PROD_PROJECT_ID
REGION=us-east1
SERVICE=nido-api
MIGRATION_JOB=nido-api-migrations
REPO=nido
SQL_INSTANCE=REPLACE_ME_PROD_SQL_INSTANCE
FIREBASE_PROJECT_ID=REPLACE_ME_PROD_FIREBASE_PROJECT_ID
FIREBASE_HOSTING_SITE=REPLACE_ME_PROD_FIREBASE_HOSTING_SITE
RUNTIME_SERVICE_ACCOUNT=nido-api-runtime@REPLACE_ME_PROD_PROJECT_ID.iam.gserviceaccount.com

CLOUD_RUN_MEMORY=1Gi
CLOUD_RUN_CPU=1
CLOUD_RUN_CONCURRENCY=80
CLOUD_RUN_TIMEOUT=300
CLOUD_RUN_MIN_INSTANCES=1
CLOUD_RUN_MAX_INSTANCES=20

RUN_MIGRATIONS=true
DB_MIGRATIONS_RUN=false
DB_MIGRATION_TRANSACTION_MODE=all
DB_USER=nido_api
DB_NAME=nido

ADMIN_EMAILS=REPLACE_ME_PROD_ADMIN_EMAILS
GCS_INGESTION_BUCKET=REPLACE_ME_PROD_INGESTION_BUCKET
GEMINI_MODEL=gemini-2.5-flash
CONCERT_SYNC_GEMINI_ENABLED=false
CONCERT_SYNC_MAX_EVENTS_PER_JOB=25
GOOGLE_CALENDAR_SERVICE_ACCOUNT_EMAIL=REPLACE_ME_PROD_CALENDAR_SERVICE_ACCOUNT
CORS_ORIGINS=https://REPLACE_ME_PROD_DOMAIN

DB_PASSWORD_SECRET=REPLACE_ME_PROD_DB_PASSWORD_SECRET:latest
FIREBASE_PRIVATE_KEY_SECRET=REPLACE_ME_PROD_FIREBASE_PRIVATE_KEY_SECRET:latest
GEMINI_API_KEY_SECRET=REPLACE_ME_PROD_GEMINI_API_KEY_SECRET:latest
GOOGLE_CALENDAR_PRIVATE_KEY_SECRET=REPLACE_ME_PROD_GOOGLE_CALENDAR_PRIVATE_KEY_SECRET:latest

# GitHub repository variables for .github/workflows/deploy-dev.yml.
# These values are consumed as `${{ vars.* }}` by GitHub Actions.
# Do not put private keys, service account JSON, DB passwords, or API runtime secrets here.
#
# Backend deploy/runtime configuration is now stored in:
# .github/deploy/environments/dev.env
# .github/deploy/environments/prod.env.example

# Optional. If omitted, the workflow resolves the Cloud Run URL after API deploy.
VITE_API_BASE_URL=https://nido-api-81555493719.us-east1.run.app

# Optional. If omitted, the workflow uses CORS_ORIGINS from the selected environment file.
CORS_ORIGINS=https://nido-api-9ed65.web.app,https://nido-api-9ed65.firebaseapp.com,http://localhost:5173

# Frontend admin allowlist.
VITE_ADMIN_EMAILS=admin@example.com

# Backend runtime env is set by .github/deploy/environments/dev.env and should match live dev.
# ADMIN_EMAILS is intentionally stored as a GitHub repository variable, not in tracked env files.
# - GEMINI_MODEL=gemini-2.5-flash
# - CONCERT_SYNC_GEMINI_ENABLED=false
# - DB_SYNCHRONIZE=false
# - RUN_MIGRATIONS=true
# - DB_MIGRATIONS_RUN=false
# Runtime secrets stay in Secret Manager, not GitHub variables.

# Firebase Web App config. These are public browser config values, not Firebase Admin credentials.
VITE_FIREBASE_API_KEY=<firebase-web-api-key>
VITE_FIREBASE_AUTH_DOMAIN=nido-api-9ed65.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=nido-api-9ed65
VITE_FIREBASE_STORAGE_BUCKET=nido-api-9ed65.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=<firebase-messaging-sender-id>
VITE_FIREBASE_APP_ID=<firebase-web-app-id>

# This workflow authenticates to Google Cloud and Firebase Hosting with
# Workload Identity Federation. Do not add a long-lived deploy service account
# JSON secret unless the workflow is intentionally moved away from WIF.

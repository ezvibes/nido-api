# Local API environment template.
# Copy this file to `.env` and fill in local values.
# Do not commit `.env`, private keys, service account JSON, database passwords,
# Firebase tokens, Google access tokens, or API keys.

# Server
PORT=3001
NODE_ENV=development

# PostgreSQL
# These defaults match docker-compose.yml for local development.
DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=nido

# Local convenience only. For deployed environments and schema PRs, prefer
# DB_SYNCHRONIZE=false plus TypeORM migrations.
DB_SYNCHRONIZE=true

# CORS
# Comma-separated list of allowed browser origins.
CORS_ORIGINS=http://localhost:5173

# Firebase Admin SDK
# Required for real Firebase token verification.
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks.
FIREBASE_PRIVATE_KEY=

# Local API development only. When true and NODE_ENV is not production,
# FirebaseAuthGuard accepts x-dev-user-* headers instead of a Firebase ID token.
AUTH_DEV_BYPASS=false

# Admin access
# Comma-separated emails allowed to access admin-only API routes.
ADMIN_EMAILS=admin@example.com

# Google Cloud Storage ingestion
# Required only when testing real image upload storage.
GCS_INGESTION_BUCKET=

# GCP credentials for local development.
# Prefer Application Default Credentials or a local, ignored service account file.
# Example:
# GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
GCP_SERVICE_ACCOUNT_PATH=
GCP_SERVICE_ACCOUNT_JSON=
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks.
GCP_PRIVATE_KEY=

# Gemini concert sync enrichment
# Leave disabled unless intentionally testing paid/model-backed extraction.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CONCERT_SYNC_GEMINI_ENABLED=false

# Concert sync extraction policy
CONCERT_SYNC_ALLOWED_GENRES=Hip Hop,Latin,Metal,Electronic,Jazz,Country,R&B,Indie,Rock,Pop,Live
CONCERT_SYNC_MIN_CONFIDENCE=0.6
CONCERT_SYNC_REQUIRE_VENUE=true
CONCERT_SYNC_REQUIRE_ARTIST=true
CONCERT_SYNC_MAX_DESCRIPTION_LENGTH=1200
CONCERT_SYNC_MAX_EVENTS_PER_JOB=25

# Google Calendar sync source
# Recommended for deployed demos: share the source calendar with a service
# account and grant "See all event details".
GOOGLE_CALENDAR_SERVICE_ACCOUNT_EMAIL=
# Use a single-line key with \n for line breaks.
GOOGLE_CALENDAR_SERVICE_ACCOUNT_PRIVATE_KEY=
# Alternative: paste the full service account JSON as a single-line string.
GOOGLE_CALENDAR_SERVICE_ACCOUNT_JSON=
# Local/manual fallback only. Short-lived OAuth token, not recommended for deploys.
GOOGLE_CALENDAR_ACCESS_TOKEN=

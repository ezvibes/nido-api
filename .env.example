DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=nido
# Auto-create tables in development (TypeORM synchronize)
DB_SYNCHRONIZE=true

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks
FIREBASE_PRIVATE_KEY=
# Legacy fallback supported in code only for older local env files:
# FIREBASE_PRIVATE_KEY_ID=

# Local API development only. When true and NODE_ENV is not production,
# FirebaseAuthGuard accepts x-dev-user-* headers instead of a Firebase ID token.
AUTH_DEV_BYPASS=false

# Google Cloud Storage ingestion
# These can reuse the same service account as Firebase Admin if desired.
# Alternative: set GOOGLE_APPLICATION_CREDENTIALS to a service account JSON file path.
# Or provide a JSON string / path below (useful for local dev or simple deploys).
GCP_SERVICE_ACCOUNT_JSON=
GCP_SERVICE_ACCOUNT_PATH=
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks
GCP_PRIVATE_KEY=
GCS_INGESTION_BUCKET=

# GitHub MCP auth
GITHUB_TOKEN=

# Admin (comma-separated emails)
ADMIN_EMAILS=ezvibesinc@gmail.com

# Gemini extraction
GEMINI_API_KEY=
# Optional. Defaults to gemini-2.0-flash in code.
GEMINI_MODEL=gemini-2.0-flash

# Concert sync extraction policy
CONCERT_SYNC_ALLOWED_GENRES=Hip Hop,Latin,Metal,Electronic,Jazz,Country,R&B,Indie,Rock,Pop,Live
CONCERT_SYNC_MIN_CONFIDENCE=0.6
CONCERT_SYNC_REQUIRE_VENUE=true
CONCERT_SYNC_REQUIRE_ARTIST=true
CONCERT_SYNC_MAX_DESCRIPTION_LENGTH=1200

# Autonomous concert sync scheduler
CONCERT_SYNC_SCHEDULER_ENABLED=true
CONCERT_SYNC_SCHEDULER_POLL_MS=60000
# Base64-encoded 32-byte key (example generation: openssl rand -base64 32)
CONCERT_SYNC_TOKEN_ENCRYPTION_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

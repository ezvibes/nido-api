DB_HOST=localhost
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=nido

# Firebase Admin SDK
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks
FIREBASE_PRIVATE_KEY=
# Legacy fallback supported in code only for older local env files:
# FIREBASE_PRIVATE_KEY_ID=

# Google Cloud Storage ingestion
# These can reuse the same service account as Firebase Admin if desired.
GCP_PROJECT_ID=
GCP_CLIENT_EMAIL=
# Use a single-line key with \n for line breaks
GCP_PRIVATE_KEY=
GCS_INGESTION_BUCKET=

# GitHub MCP auth
GITHUB_TOKEN=
